{
  "name": "agent-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Channel-agnostic agent bridge for routing chat tasks to local CLI providers.",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "setup": "node src/index.js setup",
    "service:install": "node src/index.js service-install",
    "service:remove": "node src/index.js service-remove",
    "service:print": "node src/index.js service-print",
    "service:path": "node src/index.js service-path",
    "service:start": "systemctl --user start agent-bridge.service",
    "service:stop": "systemctl --user stop agent-bridge.service",
    "service:restart": "systemctl --user restart agent-bridge.service",
    "service:status": "systemctl --user status agent-bridge.service --no-pager",
    "service:logs": "journalctl --user -u agent-bridge.service -f",
    "test": "node --test test/*.test.js"
  },
  "engines": {
    "node": ">=18.18"
  }
}
